# Copy to .env for local dev. Never commit .env to git.

# === Auth ===
# Your Anthropic API key — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# === Model ===
# AGENT_MODEL=claude-haiku-4-5-20251001

# === Observability (optional) ===
# Remove if not using Langfuse — https://cloud.langfuse.com (free tier available)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# === Agent behavior ===
# DEFAULT_SYSTEM_PROMPT=You are a helpful assistant. Use the tools available to answer questions or complete tasks.
MAX_TURNS=40
EXPOSE_TOOL_RESULTS=false
LOG_LEVEL=INFO

# === OpenWebUI registration (optional) ===
# Set these to auto-register the agent in an OpenWebUI instance on deploy
# OPENWEBUI_URL=http://localhost:3000
# OPENWEBUI_ADMIN_KEY=your-openwebui-admin-key
