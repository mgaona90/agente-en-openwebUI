# Schedule your agent via Dagger.
#
# 1. Rename this file: `mv .mlops/airflow.yaml.example .mlops/airflow.yaml`
# 2. Edit the schedule and the prompt below.
# 3. `git push`. CI generates and pushes the DAG to mlops/dagger-airflow-dags.
#
# Reference: https://gitlab.scanntech.com/mlops/agent-platform/-/blob/main/developer-layer/scheduling-agents.md

defaults:
  team: mlops

  # Dagger's defaults are Spark-sized (cpu: 8, memory: 80Gi). Override so the
  # pod for a curl-only step schedules reliably on any cluster.
  cpu: "100m"
  memory: "128Mi"

  airflow:
    # Skip Airflow's default "create paused". First scheduled fire happens
    # automatically; no manual PATCH /api/v1/dags/.../is_paused needed.
    is_paused_upon_creation: false

invoke_agent:
  # Cron in UTC unless you add `timezone:`. Examples:
  #   "0 6 * * *"     daily at 06:00 UTC
  #   "0 */6 * * *"   every 6 hours
  #   "0 9 * * 1"     Mondays at 09:00 UTC
  schedule: "0 6 * * *"
  steps:
    invoke:
      # IMPORTANT: the command MUST be a single line. Dagger's emit at
      # dag_generator.py:307 escapes " and \ but not newlines, so a YAML `|`
      # block scalar would render invalid Python in the generated DAG.
      command: "curl -fsS -X POST -H 'Content-Type: application/json' -d '{\"model\":\"e2e-test-agent6\",\"messages\":[{\"role\":\"user\",\"content\":\"REPLACE THIS WITH WHAT YOU WANT THE AGENT TO DO\"}]}' http://e2e-test-agent6.e2e-test-agent6-dev.svc.cluster.local:8000/v1/chat/completions"
